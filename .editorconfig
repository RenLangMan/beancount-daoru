# EditorConfig - 统一不同编辑器的格式
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
max_line_length = 80

[*.{yaml,yml}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.toml]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf
# 以下配置会被 shfmt 识别
switch_case_indent = true  # 某些版本支持
space-redirects = false  # 这个选项控制重定向操作符的空格，false 表示无空格

[Makefile]
indent_style = tab

[*.{cmd,bat}]
end_of_line = crlf

[COMMIT_EDITMSG]
max_line_length = 72
