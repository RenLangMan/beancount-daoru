# .env.example - 复制为 .env 并修改

# ===== UV 配置 =====
export UV_LINK_MODE="copy"

# 使用国内镜像源加速（根据你的网络选择）
# 清华源（推荐）
# export UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
# 或阿里源
# export UV_INDEX_URL="https://mirrors.aliyun.com/pypi/simple/"
# 或腾讯源
export UV_INDEX_URL="https://mirrors.cloud.tencent.com/pypi/simple"

# 增加并发下载数（加速）
export UV_CONCURRENT_DOWNLOADS=50

# 设置缓存目录（可选）
export UV_CACHE_DIR="${HOME}/.cache/uv"

# ===== 自定义路径（仅在 Windows 且 uv/python 不在 PATH 时使用）=====
# 在 Linux/macOS 下通常不需要，因为 uv 和 python 应已加入 PATH
# export UV_PATH="H:/dev/dev_envs/uv"
# export PYTHON_PATH="H:/dev/dev_envs/uv/python/cpython-3.12.12-windows-x86_64-none"

# ===== 项目配置 =====
export PROJECT_ROOT="/workspace"   # 在容器中，可改为实际路径；本地 Windows 可留空或注释
