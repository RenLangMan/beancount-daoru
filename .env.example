# .env.example - 复制为 .env 并修改

# ===== UV 配置 =====
export UV_LINK_MODE="copy"

# 使用国内镜像源加速（根据你的网络选择）
# 清华源（推荐）
# export UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
# 或阿里源
# export UV_INDEX_URL="https://mirrors.aliyun.com/pypi/simple/"
# 或腾讯源
export UV_INDEX_URL="https://mirrors.cloud.tencent.com/pypi/simple"

# 增加并发下载数（加速）
export UV_CONCURRENT_DOWNLOADS=50

# 设置缓存目录（可选）
export UV_CACHE_DIR="${HOME}/.cache/uv"

# ===== 自定义路径（仅在 Windows 且 uv/python 不在 PATH 时使用）=====
# 在 Linux/macOS 下通常不需要，因为 uv 和 python 应已加入 PATH
# export UV_PATH="H:/dev/dev_envs/uv"
# export PYTHON_PATH="H:/dev/dev_envs/uv/python/cpython-3.12.12-windows-x86_64-none"

# ===== 项目配置 =====
export PROJECT_ROOT="/workspace"   # 在容器中，可改为实际路径；本地 Windows 可留空或注释

# ===== LLM (llama.cpp) 配置 =====
# llama-server 可执行文件路径（可选，默认查找系统 PATH）
# Linux/macOS: export LLAMA_SERVER="/usr/local/bin/llama-server"
# Windows:     export LLAMA_SERVER="H:/dev/llama.cpp/build/bin/Release/llama-server.exe"

# ===== 根据操作系统设置 LLM 路径 =====
case "$OSTYPE" in
  msys* | cygwin* | win32* | mingw*)
    # Windows 环境
    IS_WINDOWS=true
    # Windows 下的模型目录（建议放在用户目录下）
    LLAMA_MODEL_DIR="${HOME}/models"
    # Windows 下的 llama-server 路径
    # export LLAMA_SERVER="H:/dev/llama.cpp/build/bin/Release/llama-server.exe"
    ;;
  *)
    # Linux/macOS 环境
    IS_WINDOWS=false
    # Linux/macOS 下的模型目录（Docker 容器内）
    LLAMA_MODEL_DIR="/opt/models"
    # Linux/macOS 下的 llama-server 路径（默认已加入 PATH，可不设置）
    # export LLAMA_SERVER="/usr/local/bin/llama-server"
    ;;
esac

# ===== 模型文件配置 =====
# 默认模型（用于一般使用）
export LLAMA_MODEL="${LLAMA_MODEL_DIR}/tinyllama.gguf"

# 测试模型（用于 pytest，优先级高于 LLAMA_MODEL）
# Embedding 模型（用于向量嵌入测试）
export TEST_EMBEDDING_MODEL="${LLAMA_MODEL_DIR}/embeddinggemma-300m-Q4_0.gguf"

# Chat Completion 模型（用于对话补全测试）
export TEST_CHAT_MODEL="${LLAMA_MODEL_DIR}/qwen3-4b-instruct-2507-iq4_nl.gguf"

# 备用模型（当主模型不可用时使用）
export TEST_FALLBACK_MODEL="${LLAMA_MODEL_DIR}/tinyllama.gguf"

# 服务配置
export LLAMA_HOST="0.0.0.0"
export LLAMA_PORT="8080"

# GPU 层数（CPU 模式设为 0，GPU 模式设为较大值如 99）
export LLAMA_N_GPU_LAYERS="99"

# 上下文大小
export LLAMA_CONTEXT_SIZE="2048"
