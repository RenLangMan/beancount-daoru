FROM cnbcool/default-dev-env:latest

# 设置镜像源加速
ENV PIP_INDEX_URL=https://mirrors.cloud.tencent.com/pypi/simple/
ENV NPM_REGISTRY=https://mirrors.cloud.tencent.com/npm/
ENV GOPROXY=https://goproxy.cn,direct

# 安装 C 编译工具链和 bison（解决 beancount==3.2.0 原生编译问题）
RUN apt-get update && apt-get install -y \
    build-essential \
    bison \
    flex \
    libffi-dev \
    libssl-dev \
    cmake \
    && rm -rf /var/lib/apt/lists/*

# 安装 Go 1.22（如果基础镜像没有或版本太新）
RUN if ! command -v go &> /dev/null || [[ $(go version | grep -oP 'go\K[0-9.]+') < 1.22 ]]; then \
        curl -fsSL https://go.dev/dl/go1.22.5.linux-amd64.tar.gz | tar -C /usr/local -xzf - && \
        echo "export PATH=\$PATH:/usr/local/go/bin" >> /root/.bashrc; \
    fi
ENV PATH=$PATH:/usr/local/go/bin

# 安装 Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# 安装 markdownlint-cli2
RUN npm install -g markdownlint-cli2

# 安装 basedpyright
RUN npm install -g basedpyright

# 安装 shellcheck（Shell 脚本静态检查）
RUN apt-get update && apt-get install -y shellcheck \
    && rm -rf /var/lib/apt/lists/*

# 安装 shfmt（Shell 脚本格式化）
RUN go install mvdan.cc/sh/v3/cmd/shfmt@latest \
    && ln -sf $(go env GOPATH)/bin/shfmt /usr/local/bin/shfmt

# 安装并固定 Python 3.12（覆盖默认版本）
RUN uv python install 3.12 && \
    uv python pin 3.12 && \
    # 确保 PATH 包含 uv 的 bin 目录
    export PATH="/root/.local/bin:$PATH" && \
    PYTHON312_PATH=$(uv python find 3.12) && \
    ln -sf "$PYTHON312_PATH" /usr/local/bin/python && \
    # 验证 Python 版本
    python --version

# 安装 ruff（通过 uv 作为全局工具）
RUN uv tool install ruff

# 安装 pre-commit（通过 uv 作为全局工具）
RUN uv tool install pre-commit --with pre-commit-uv

# ==================== llama.cpp 集成 ====================
# 确保 cmake 存在
RUN command -v cmake || (apt-get update && apt-get install -y cmake && rm -rf /var/lib/apt/lists/*)

# 编译 llama.cpp（预编译，加速云原生开发环境启动）
RUN git clone https://github.com/ggerganov/llama.cpp /opt/llama.cpp && \
    cd /opt/llama.cpp && \
    mkdir build && cd build && \
    cmake .. -DLLAMA_CURL=ON && \
    cmake --build . --config Release -j $(nproc) && \
    ln -sf /opt/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server && \
    ln -sf /opt/llama.cpp/build/bin/llama-cli /usr/local/bin/llama-cli && \
    # 下载轻量测试模型（TinyLlama ~600MB，用于快速验证）
    mkdir -p /opt/models && \
    curl -L -o /opt/models/tinyllama.gguf \
      https://huggingface.co/TheBloke/TinyLlama-1.1B-GGUF/resolve/main/tinyllama-1.1b-q4_k_m.gguf

# 创建启动脚本（支持环境变量配置）
RUN cat > /usr/local/bin/start-llama << 'EOF'
#!/bin/bash
# llama-server 启动脚本
# 环境变量说明：
#   LLAMA_MODEL: 模型文件路径（默认: /opt/models/tinyllama.gguf）
#   LLAMA_HOST: 监听地址（默认: 0.0.0.0）
#   LLAMA_PORT: 监听端口（默认: 8080）
#   LLAMA_N_GPU_LAYERS: GPU 层数（默认: 99，CPU 模式设为 0）
#   LLAMA_CONTEXT_SIZE: 上下文大小（默认: 2048）
#   LLAMA_THREADS: CPU 线程数（默认: 自动）

MODEL="${LLAMA_MODEL:-/opt/models/tinyllama.gguf}"
HOST="${LLAMA_HOST:-0.0.0.0}"
PORT="${LLAMA_PORT:-8080}"
N_GPU_LAYERS="${LLAMA_N_GPU_LAYERS:-99}"
CTX_SIZE="${LLAMA_CONTEXT_SIZE:-2048}"
THREADS="${LLAMA_THREADS:-}"

echo "🚀 启动 llama-server"
echo "  模型: $MODEL"
echo "  地址: $HOST:$PORT"
echo "  GPU 层数: $N_GPU_LAYERS"
echo "  上下文大小: $CTX_SIZE"

# 检查模型文件是否存在
if [ ! -f "$MODEL" ]; then
    echo "❌ 错误: 模型文件不存在: $MODEL"
    exit 1
fi

# 构建命令
CMD="llama-server -m $MODEL --host $HOST --port $PORT -ngl $N_GPU_LAYERS -c $CTX_SIZE"

# 添加线程数参数（如果指定）
if [ -n "$THREADS" ]; then
    CMD="$CMD -t $THREADS"
fi

echo "执行: $CMD"
exec $CMD
EOF

# 创建停止脚本
RUN cat > /usr/local/bin/stop-llama << 'EOF'
#!/bin/bash
echo "🛑 停止 llama-server..."
pkill -f "llama-server" && echo "✅ 已停止" || echo "⚠️ 没有运行中的服务"
EOF

# 创建状态检查脚本
RUN cat > /usr/local/bin/status-llama << 'EOF'
#!/bin/bash
if pgrep -f "llama-server" > /dev/null; then
    PID=$(pgrep -f "llama-server")
    # 使用 ss 替代 netstat（更现代）
    PORT=$(ss -tlnp 2>/dev/null | grep "$PID" | grep -oP ':\K\d+' | head -1)
    echo "✅ llama-server 运行中 (PID: $PID, 端口: ${PORT:-未知})"
    exit 0
else
    echo "❌ llama-server 未运行"
    exit 1
fi
EOF

# 创建测试脚本
RUN cat > /usr/local/bin/test-llama << 'EOF'
#!/bin/bash
# 测试 llama-server API 是否可用
PORT="${LLAMA_PORT:-8080}"
HOST="${LLAMA_HOST:-0.0.0.0}"

echo "🔍 测试 llama-server API (http://$HOST:$PORT)"
sleep 2

# 健康检查
if curl -s "http://$HOST:$PORT/health" > /dev/null 2>&1; then
    echo "✅ 服务健康检查通过"
else
    echo "❌ 服务健康检查失败"
    exit 1
fi

# 测试补全接口
echo '{"prompt":"Hello","n_predict":10}' | \
    curl -s -X POST "http://$HOST:$PORT/completion" \
    -H "Content-Type: application/json" \
    -d @- > /dev/null && echo "✅ 补全接口测试通过" || echo "⚠️ 补全接口测试失败"
EOF

RUN chmod +x /usr/local/bin/start-llama \
    /usr/local/bin/stop-llama \
    /usr/local/bin/status-llama \
    /usr/local/bin/test-llama

# ==================== 验证工具版本 ====================
RUN echo "=== Tool Versions ===" && \
    echo "Go: $(go version 2>/dev/null || echo 'not found')" && \
    echo "Node: $(node --version 2>/dev/null || echo 'not found')" && \
    echo "npm: $(npm --version 2>/dev/null || echo 'not found')" && \
    echo "markdownlint-cli2: $(markdownlint-cli2 --version 2>/dev/null || echo 'not found')" && \
    echo "basedpyright: $(basedpyright --version 2>/dev/null || echo 'not found')" && \
    echo "shellcheck: $(shellcheck --version 2>/dev/null | head -n1 || echo 'not found')" && \
    echo "shfmt: $(shfmt --version 2>/dev/null || echo 'not found')" && \
    echo "uv: $(uv --version 2>/dev/null || echo 'not found')" && \
    echo "Python: $(python --version 2>/dev/null || echo 'not found')" && \
    echo "ruff: $(ruff --version 2>/dev/null || echo 'not found')" && \
    echo "pre-commit: $(pre-commit --version 2>/dev/null | head -n1 || echo 'not found')" && \
    echo "gcc: $(gcc --version 2>/dev/null | head -n1 || echo 'not found')" && \
    echo "bison: $(bison --version 2>/dev/null | head -n1 || echo 'not found')" && \
    echo "cmake: $(cmake --version 2>/dev/null | head -n1 || echo 'not found')" && \
    echo "llama-server: $(llama-server --version 2>&1 | head -n1 || echo 'installed')" && \
    echo "===================="

WORKDIR /workspace
